@prefix dec:    <https://w3id.org/iladub/dec#> .
@prefix etkl:   <https://w3id.org/iladub/etkl#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:<http://purl.org/dc/terms/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix vann:   <http://purl.org/vocab/vann/> .

#################################################################
#  Ontology metadata
#################################################################

<https://w3id.org/iladub/dec> a owl:Ontology ;
    dcterms:title "dec — decision-context vocabulary"@en ;
    dcterms:description """Represents decisions as holons: units that are at once a
self-contained, accountable deliberation and a part of a larger decision holarchy. A
dec:DecisionHolon is a prov:Activity that records the evidence considered, the constraints
in force, the option space deliberated (the no-change option counts), the single chosen
option, the accountable agent, a rationale, and what the decision produced — plus its place
in a holarchy and the autonomy scope it acted within. It captures what most data models
(e.g. FHIR) structurally cannot: the rejected option and why, situated meaning, a holarchy
of authority, the deontic layer, and decision lineage."""@en ;
    dcterms:creator "François Rosselet" ;
    dcterms:created "2026-05-31"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.1.0" ;
    vann:preferredNamespacePrefix "dec" ;
    vann:preferredNamespaceUri "https://w3id.org/iladub/dec#" ;
    rdfs:seeAlso <https://w3id.org/iladub/etkl> , <https://w3id.org/iladub> .

#################################################################
#  Classes
#################################################################

dec:DecisionHolon a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Decision Holon"@en ;
    rdfs:comment "An accountable, re-evaluable decision that is simultaneously a whole (a self-contained deliberation) and a part (a member of a larger decision holarchy)."@en .

dec:Option a owl:Class ;
    rdfs:label "Option"@en ;
    rdfs:comment "A candidate course of action in a decision's option space. The no-change option is a legitimate option."@en .

dec:Scope a owl:Class ;
    rdfs:label "Autonomy Scope"@en ;
    rdfs:comment "The bounds of authority within which a decision (especially an automated one) may act."@en .

#################################################################
#  Properties — deliberation
#################################################################

dec:consideredEvidence a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:label "considered evidence"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range prov:Entity ;
    rdfs:comment "An item of evidence the decision took into account."@en .

dec:constrainedBy a owl:ObjectProperty ;
    rdfs:label "constrained by"@en ; rdfs:domain dec:DecisionHolon ;
    rdfs:comment "A constraint that reframed the option space (e.g. a contraindication)."@en .

dec:optionSpace a owl:ObjectProperty ;
    rdfs:label "option space"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:Option ;
    rdfs:comment "An option that was available to the decision. A real decision has at least two."@en .

dec:chosen a owl:ObjectProperty ;
    rdfs:label "chosen"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:Option ;
    rdfs:comment "The single option the decision selected. Must be a member of the option space."@en .

dec:decidedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:label "decided by"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range prov:Agent ;
    rdfs:comment "The accountable agent (human or automated) that made the decision."@en .

dec:rationale a owl:DatatypeProperty ;
    rdfs:label "rationale"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range rdfs:Literal ;
    rdfs:comment "Why the chosen option was selected (may be language-tagged)."@en .

dec:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range xsd:decimal ;
    rdfs:comment "Decider confidence in the choice, in [0,1]."@en .

dec:produced a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:label "produced"@en ; rdfs:domain dec:DecisionHolon ;
    rdfs:comment "The node or artifact the decision produced (e.g. a prescription, a grounded node)."@en .

#################################################################
#  Properties — option detail
#################################################################

dec:rejectedBecause a owl:DatatypeProperty ;
    rdfs:label "rejected because"@en ; rdfs:domain dec:Option ; rdfs:range rdfs:Literal ;
    rdfs:comment "Why this option was not chosen (may be language-tagged)."@en .

dec:dominatedBy a owl:ObjectProperty ;
    rdfs:label "dominated by"@en ; rdfs:domain dec:Option ; rdfs:range dec:Option ;
    rdfs:comment "Another option that dominated this one in the deliberation."@en .

#################################################################
#  Properties — holarchy, governance, lineage
#################################################################

dec:partOf a owl:ObjectProperty ;
    rdfs:label "part of"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:DecisionHolon ;
    rdfs:comment "The larger decision holon this one composes into (local ⊂ protocol ⊂ guideline ⊂ policy)."@en .

dec:governedBy a owl:ObjectProperty ;
    rdfs:label "governed by"@en ; rdfs:domain dec:DecisionHolon ;
    rdfs:comment "The policy, guideline or protocol that governs the decision."@en .

dec:withinScope a owl:ObjectProperty ;
    rdfs:label "within scope"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:Scope ;
    rdfs:comment "The autonomy scope the decision acted within."@en .

dec:revisitIf a owl:DatatypeProperty ;
    rdfs:label "revisit if"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range rdfs:Literal ;
    rdfs:comment "A condition that, if it becomes true, should reopen this decision (decision lineage)."@en .

#################################################################
#  Timeline / process holarchy (SP2)
#################################################################

dec:Process a owl:Class ;
    rdfs:label "Process"@en ;
    rdfs:comment "A holon whose parts are milestone decisions ordered over time — a time-critical supply chain."@en .

dec:Milestone a owl:Class ;
    rdfs:label "Milestone"@en ;
    rdfs:comment "A decision point in a process, with a required-context contract and optional clock role."@en .

dec:hasMilestone a owl:ObjectProperty ;
    rdfs:label "has milestone"@en ; rdfs:domain dec:Process ; rdfs:range dec:Milestone .

dec:order a owl:DatatypeProperty ;
    rdfs:label "order"@en ; rdfs:domain dec:Milestone ; rdfs:range xsd:integer ;
    rdfs:comment "Position of the milestone in the process sequence."@en .

dec:requiresContext a owl:ObjectProperty ;
    rdfs:label "requires context"@en ; rdfs:domain dec:Milestone ; rdfs:range etkl:SemanticDataContract ;
    rdfs:comment "The required-context contract that must be ready before this milestone's decision. Range is etkl:SemanticDataContract by design: dec is part of the ET(K)L family (etkl ⊇ dec ⊇ iladub), so this is within-family layering, not a domain coupling."@en .

dec:clockStart a owl:DatatypeProperty ;
    rdfs:label "clock start"@en ; rdfs:domain dec:Milestone ; rdfs:range xsd:boolean ;
    rdfs:comment "True if this milestone starts the dominant time-critical interval."@en .

dec:clockStop a owl:DatatypeProperty ;
    rdfs:label "clock stop"@en ; rdfs:domain dec:Milestone ; rdfs:range xsd:boolean ;
    rdfs:comment "True if this milestone stops the dominant time-critical interval."@en .

dec:windowLimitMinutes a owl:DatatypeProperty ;
    rdfs:label "window limit (minutes)"@en ; rdfs:domain dec:Milestone ; rdfs:range xsd:integer ;
    rdfs:comment "The maximum duration of the interval this milestone opens (e.g. cold-ischemia limit)."@en .

dec:withinProcess a owl:ObjectProperty ;
    rdfs:label "within process"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:Process ;
    rdfs:comment "The process holarchy this milestone decision belongs to (decision → process; distinct from dec:partOf, which is decision → decision)."@en .

#################################################################
#  Events & decision lineage (SP3a)
#################################################################

dec:Event a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Event"@en ;
    rdfs:comment "A perturbation that may reopen a decision when it matches the decision's dec:revisitIf."@en .

dec:condition a owl:DatatypeProperty ;
    rdfs:label "condition"@en ; rdfs:domain dec:Event ; rdfs:range rdfs:Literal ;
    rdfs:comment "The named trigger key this event carries (matched against a decision's dec:revisitIf)."@en .

dec:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:DecisionHolon ;
    rdfs:comment "This (re-evaluated) decision supersedes a prior decision — decision lineage."@en .

dec:triggeredBy a owl:ObjectProperty ;
    rdfs:label "triggered by"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:Event ;
    rdfs:comment "The event that caused this decision to be reopened."@en .

#################################################################
#  Apex escalation — vertical authority-holarchy lineage
#################################################################

dec:escalatedTo a owl:ObjectProperty ;
    rdfs:label "escalated to"@en ; rdfs:domain dec:DecisionHolon ; rdfs:range dec:DecisionHolon ;
    rdfs:comment "This decision escalated the matter to a higher-authority decision because the local decision's autonomy scope was insufficient to resolve it (authority-holarchy lineage; the vertical analog of dec:supersedes)."@en .

dec:maxSeverity a owl:ObjectProperty ;
    rdfs:label "max severity"@en ; rdfs:domain dec:Scope ;
    rdfs:comment "The highest severity the scope's holder may resolve within its own autonomy; a realized severity above it must be escalated. The filler is an ordinal severity resource (in practice a risk:Severity) — dec stays standalone, so the range is left open."@en .
