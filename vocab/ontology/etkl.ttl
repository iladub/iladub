@prefix etkl:   <https://w3id.org/etkl#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:<http://purl.org/dc/terms/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix vann:   <http://purl.org/vocab/vann/> .

#################################################################
#  Ontology metadata
#################################################################

<https://w3id.org/etkl> a owl:Ontology ;
    dcterms:title "ET(K)L — Extract, Transform-with-(K)nowledge, Load"@en ;
    dcterms:description """The umbrella vocabulary for the ET(K)L method: knowledge
engineering is the first milestone of the pipeline, not the last. A SemanticDataContract
declares the target semantics (target SHACL shapes and required knowledge modules), and a
KnowledgeModule is passed as an argument of the Transformation — never reconstructed by a
mapping at the end. Conformance is checkable: every contract declares a target shape and a
knowledge module; every transformation has a knowledge argument and a governing contract;
every extraction applies a contract; every source declares its format."""@en ;
    dcterms:creator "François Rosselet" ;
    dcterms:created "2026-05-31"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.2.0" ;
    vann:preferredNamespacePrefix "etkl" ;
    vann:preferredNamespaceUri "https://w3id.org/etkl#" ;
    rdfs:seeAlso <https://w3id.org/etkl/hol> , <https://w3id.org/etkl/iladub> .

#################################################################
#  Core classes
#################################################################

etkl:SemanticDataContract a owl:Class ;
    rdfs:label "Semantic Data Contract"@en ;
    rdfs:comment "Declares the target semantics of a transformation: the target SHACL shape(s), terminology bindings, and the knowledge module(s) the transform requires. The contract is an ontology, not a JSON/YAML schema."@en .

etkl:KnowledgeModule a owl:Class ;
    rdfs:label "Knowledge Module"@en ;
    rdfs:comment "A reusable OWL/SKOS/SHACL artifact that can be passed as an argument to a transformation."@en .

etkl:Extraction a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Extraction"@en ;
    rdfs:comment "Knowledge-guided reading of a source: it applies a contract while reading, so knowledge enters first."@en .

etkl:Transformation a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Transformation"@en ;
    rdfs:comment "Takes a knowledge module as an argument and is governed by a contract."@en .

etkl:Load a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Load"@en ;
    rdfs:comment "Loads the contract-validated output graph."@en .

etkl:SourceDocument a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Source Document"@en ;
    rdfs:comment "An input document. It declares its format."@en .

etkl:Field a owl:Class ;
    rdfs:label "Field"@en ;
    rdfs:comment "A contract field: binds a target property to an extractable value, optionally constrained to an admissible terminology scheme. Read by the knowledge-guided (BAML) extractor."@en .

#################################################################
#  Core properties
#################################################################

etkl:hasTargetShape a owl:ObjectProperty ;
    rdfs:label "has target shape"@en ; rdfs:domain etkl:SemanticDataContract ;
    rdfs:comment "A SHACL node shape the contract's output must conform to."@en .

etkl:requiresKnowledge a owl:ObjectProperty ;
    rdfs:label "requires knowledge"@en ; rdfs:domain etkl:SemanticDataContract ; rdfs:range etkl:KnowledgeModule ;
    rdfs:comment "A knowledge module the contract requires the transform to be given."@en .

etkl:targetClass a owl:ObjectProperty ;
    rdfs:label "target class"@en ; rdfs:domain etkl:SemanticDataContract ;
    rdfs:comment "The class the contract's primary output resource is an instance of."@en .

etkl:hasKnowledgeArgument a owl:ObjectProperty ;
    rdfs:label "has knowledge argument"@en ; rdfs:domain etkl:Transformation ; rdfs:range etkl:KnowledgeModule ;
    rdfs:comment "The knowledge module supplied to this transformation as an argument."@en .

etkl:governedByContract a owl:ObjectProperty ;
    rdfs:label "governed by contract"@en ; rdfs:domain etkl:Transformation ; rdfs:range etkl:SemanticDataContract ;
    rdfs:comment "The contract that governs this transformation."@en .

etkl:appliesContract a owl:ObjectProperty ;
    rdfs:label "applies contract"@en ; rdfs:domain etkl:Extraction ; rdfs:range etkl:SemanticDataContract ;
    rdfs:comment "The contract this extraction applies while reading (knowledge-first)."@en .

etkl:hasFormat a owl:DatatypeProperty ;
    rdfs:label "has format"@en ; rdfs:domain etkl:SourceDocument ; rdfs:range rdfs:Literal ;
    rdfs:comment "The declared format of the source document (e.g. txt, pdf, xlsx, html)."@en .

#################################################################
#  Contract fields (knowledge-guided extraction binding)
#################################################################

etkl:hasField a owl:ObjectProperty ;
    rdfs:label "has field"@en ; rdfs:domain etkl:SemanticDataContract ; rdfs:range etkl:Field ;
    rdfs:comment "A field the contract declares for extraction."@en .

etkl:fillsProperty a owl:ObjectProperty ;
    rdfs:label "fills property"@en ; rdfs:domain etkl:Field ;
    rdfs:comment "The target property this field populates on the output resource."@en .

etkl:admissibleScheme a owl:ObjectProperty ;
    rdfs:label "admissible scheme"@en ; rdfs:domain etkl:Field ;
    rdfs:comment "A SKOS concept scheme the field's value must ground to. A field WITH an admissible scheme must resolve (else the value becomes an iladub:CandidateConcept); a field WITHOUT one is asserted as a free literal."@en .

#################################################################
#  Contract-driven assembly rules (concept -> output resource)
#################################################################

etkl:ResourceRule a owl:Class ;
    rdfs:label "Resource Rule"@en ;
    rdfs:comment "A contract rule that says which output resource a recognised concept becomes and which element carries its code. Drives contract-defined assembly (e.g. concept -> FHIR resource)."@en .

etkl:buildsResource a owl:ObjectProperty ;
    rdfs:label "builds resource"@en ; rdfs:domain etkl:SemanticDataContract ; rdfs:range etkl:ResourceRule ;
    rdfs:comment "A resource rule the contract uses to build an output resource."@en .

etkl:resourceType a owl:ObjectProperty ;
    rdfs:label "resource type"@en ; rdfs:domain etkl:ResourceRule ;
    rdfs:comment "The type the rule's output resource is an instance of (e.g. a FHIR resource type)."@en .

etkl:triggerConcept a owl:ObjectProperty ;
    rdfs:label "trigger concept"@en ; rdfs:domain etkl:ResourceRule ;
    rdfs:comment "The recognised concept whose presence triggers this rule. Only emit what the source supports."@en .

etkl:bindsElement a owl:ObjectProperty ;
    rdfs:label "binds element"@en ; rdfs:domain etkl:ResourceRule ;
    rdfs:comment "The element/property on the output resource that carries the trigger concept's code."@en .
