@prefix iladub: <https://w3id.org/iladub#> .
@prefix dec:    <https://w3id.org/iladub/dec#> .
@prefix holon:  <http://w3id.org/holon/> .
@prefix gist:   <https://w3id.org/semanticarts/ns/ontology/gist/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:     <https://example.org/demo#> .

#  GOVERNED GROUNDING (conforms).
#  The full bridge: a PROPOSITION (iladub:CandidateConcept) — which HGA would
#  hold at holon:CandidateStatus — is reviewed by an accountable
#  iladub:PromotionDecision, which PRODUCES a holon:GroundingRecord that then
#  carries holon:RegisteredStatus. iladub's invariant layered onto HGA's
#  lifecycle. Passes both iladub-shapes.ttl and iladub-hga-shapes.ttl.

#  The proposition, honest about itself.
ex:cand-egfr a iladub:CandidateConcept ;
    iladub:surfaceText "eGFR"@en ;
    iladub:suggestedAnchor gist:Magnitude ;
    iladub:suggestedBy ex:extractor-v0 ;
    iladub:confidence 0.74 ;
    iladub:fromRegion ex:region-p1-tbl2 ;
    iladub:status iladub:proposed .

#  The accountable membrane-crossing.
ex:promo-egfr a iladub:PromotionDecision , dec:DecisionHolon ;
    rdfs:label "Promote 'eGFR' grounding to registered"@en ;
    iladub:reviews ex:cand-egfr ;
    dec:decidedBy ex:curator-aliki ;
    dec:optionSpace ex:opt-accept , ex:opt-reject ;
    dec:chosen ex:opt-accept ;
    dec:rationale "Fuzzy on surface form, but the table header and units make the match certain."@en ;
    dec:confidence 0.93 ;
    dec:produced ex:gr-egfr .

#  The HGA-native grounding record the decision produced: registered only
#  BECAUSE the promotion produced it (the governance shape checks exactly this).
ex:gr-egfr a holon:GroundingRecord ;
    holon:sourceString "eGFR" ;
    holon:matchType holon:FuzzyMatch ;
    holon:groundingConfidence 0.74 ;
    holon:matchedIRI ex:GlomerularFiltrationRate ;
    holon:registrationStatus holon:RegisteredStatus ;
    iladub:fromRegion ex:region-p1-tbl2 .

ex:opt-accept a dec:Option ; rdfs:label "accept the match and register"@en .
ex:opt-reject a dec:Option ; rdfs:label "reject"@en ;
    dec:rejectedBecause "Surface form alone is ambiguous, but context resolves it."@en .

ex:extractor-v0 a iladub:Suggester ; rdfs:label "iladub extractor v0 (model)"@en .
ex:curator-aliki a prov:Agent ; rdfs:label "Dr. A. Curator"@en .
ex:region-p1-tbl2 a iladub:SourceRegion ; rdfs:label "page 1, table 2"@en .
