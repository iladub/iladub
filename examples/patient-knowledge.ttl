@prefix etkl: <https://w3id.org/etkl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <https://example.org/demo#> .

#  A minimal KNOWLEDGE MODULE supplied to the transform as an argument.
#  (Kept deliberately small for the worked example.)

ex:patient-knowledge a etkl:KnowledgeModule ;
    rdfs:label "Admission terminology module"@en .

ex:Patient a skos:Concept ;
    skos:prefLabel "Patient"@en .
