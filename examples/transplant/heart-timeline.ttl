@prefix tx:     <https://example.org/transplant#> .
@prefix dec:    <https://w3id.org/iladub/dec#> .
@prefix etkl:   <https://w3id.org/iladub/etkl#> .
@prefix iladub: <https://w3id.org/iladub#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

tx:heart-process a dec:Process ;
    rdfs:label "Heart DBD transplant (M4–M8)"@en ;
    dec:hasMilestone tx:m4 , tx:m5 , tx:m6 , tx:m7 , tx:m8 .

tx:m4 a dec:Milestone ; rdfs:label "Offer → Acceptance"@en ; dec:order 4 ;
    dec:requiresContext tx:ctx-m4 .
tx:m5 a dec:Milestone ; rdfs:label "Mobilization"@en ; dec:order 5 ;
    dec:requiresContext tx:ctx-m5 .
tx:m6 a dec:Milestone ; rdfs:label "Cross-clamp"@en ; dec:order 6 ;
    dec:clockStart true ; dec:windowLimitMinutes 240 .
tx:m7 a dec:Milestone ; rdfs:label "Transport"@en ; dec:order 7 ;
    dec:requiresContext tx:ctx-m7 .
tx:m8 a dec:Milestone ; rdfs:label "Reperfusion"@en ; dec:order 8 ;
    dec:clockStop true .

tx:ctx-m4 a etkl:SemanticDataContract ; etkl:hasField tx:tf-organ , tx:tf-abo .
tx:ctx-m5 a etkl:SemanticDataContract ; etkl:hasField tx:tf-recipient-ready ;
    iladub:extractor "ExtractRecipientContext" .
tx:ctx-m7 a etkl:SemanticDataContract ; etkl:hasField tx:tf-transport , tx:tf-crossclamp .

tx:tf-organ          a etkl:Field ; etkl:fillsProperty tx:organ ;
    etkl:admissibleScheme tx:scheme-organ .
tx:tf-abo            a etkl:Field ; etkl:fillsProperty tx:aboGroup ;
    etkl:admissibleScheme tx:scheme-abo .
tx:tf-recipient-ready a etkl:Field ; etkl:fillsProperty tx:recipientReady .
tx:tf-transport      a etkl:Field ; etkl:fillsProperty tx:projectedTransportMinutes .
tx:tf-crossclamp     a etkl:Field ; etkl:fillsProperty tx:crossClampTime .
