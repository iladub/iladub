@prefix tx:   <https://example.org/transplant#> .
@prefix dec:  <https://w3id.org/iladub/dec#> .
@prefix etkl: <https://w3id.org/iladub/etkl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Kidneys tolerate long cold ischemia; the chain differs from heart: fewer,
# less time-frantic milestones, and machine perfusion replaces a cross-clamp race.
tx:kidney-process a dec:Process ;
    rdfs:label "Kidney transplant chain"@en ;
    dec:hasMilestone tx:k1 , tx:k2 , tx:k3 , tx:k4 .

tx:k1 a dec:Milestone ; rdfs:label "Accept"@en ; dec:order 1 ;
    dec:requiresContext tx:kctx-1 .
tx:k2 a dec:Milestone ; rdfs:label "Recovery (cold-store start)"@en ; dec:order 2 ;
    dec:clockStart true ; dec:windowLimitMinutes 1800 .
tx:k3 a dec:Milestone ; rdfs:label "Machine perfusion + transport"@en ; dec:order 3 ;
    dec:requiresContext tx:kctx-3 .
tx:k4 a dec:Milestone ; rdfs:label "Implant (reperfusion)"@en ; dec:order 4 ;
    dec:clockStop true .

tx:kctx-1 a etkl:SemanticDataContract ; etkl:hasField tx:tf-abo .
tx:kctx-3 a etkl:SemanticDataContract ; etkl:hasField tx:tf-transport .

tx:tf-abo       a etkl:Field ; etkl:fillsProperty tx:aboGroup .
tx:tf-transport a etkl:Field ; etkl:fillsProperty tx:projectedTransportMinutes .
