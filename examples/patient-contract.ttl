@prefix etkl: <https://w3id.org/etkl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <https://example.org/demo#> .

#  A SEMANTIC DATA CONTRACT for a free-text admission note. It declares the
#  target class and shape, requires a knowledge module, and binds target
#  properties to extraction patterns (the field rules). Knowledge first.

ex:patient-contract a etkl:SemanticDataContract ;
    rdfs:label "Admission-note patient contract"@en ;
    etkl:targetClass ex:Patient ;
    etkl:hasTargetShape ex:PatientShape ;
    etkl:requiresKnowledge ex:patient-knowledge ;
    etkl:hasFieldRule ex:rule-name , ex:rule-mrn , ex:rule-dob .

ex:rule-name a etkl:FieldRule ;
    etkl:onProperty ex:name ;
    etkl:matchesPattern "Patient:\\s*(.+)" .

ex:rule-mrn a etkl:FieldRule ;
    etkl:onProperty ex:mrn ;
    etkl:matchesPattern "MRN:\\s*(\\S+)" .

ex:rule-dob a etkl:FieldRule ;
    etkl:onProperty ex:birthDate ;
    etkl:matchesPattern "DOB:\\s*(\\d{4}-\\d{2}-\\d{2})" .
